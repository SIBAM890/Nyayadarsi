# ──────────────────────────────────────────────
# Nyayadarsi — .gitignore
# ──────────────────────────────────────────────

# ── Environment Variables (NEVER commit) ──
.env
.env.local
.env.production
.env.*.local

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ── Virtual Environment ──
venv/
.venv/
env/
ENV/

# ── Node.js ──
node_modules/
.next/
out/
.expo/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*
.yarn/

# ── Database (local dev only) ──
*.db
*.db-shm
*.db-wal
*.db-journal
*.sqlite
*.sqlite3

# ── IDE / Editor ──
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ── OS Generated ──
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Uploads (user-generated at runtime) ──
backend/uploads/

# ── Logs ──
*.log
logs/

# ── Coverage / Testing ──
htmlcov/
.coverage
.coverage.*
.pytest_cache/
.tox/

# ── Distribution ──
*.tar.gz
*.whl
