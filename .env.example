# Nyayadarsi Environment Variables
# Copy this file to .env and fill in your values

# AI API Keys (Required for extraction)
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Database
DATABASE_URL=postgresql://user:password@neon_host/dbname
REGISTERED_SITE_LAT=20.2961
REGISTERED_SITE_LON=85.8245
GPS_THRESHOLD_METERS=100

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-secure-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
